# ====================================================================
#  Trading Bot — Environment Variables
#  Copy this file to .env and fill in your credentials
# ====================================================================

# Broker mode: "paper" | "binance" | "zerodha" | "alpaca"
BROKER=paper

# ─── Zerodha KiteConnect (NSE/BSE) ────────────────────────────────
# Sign up: https://kite.trade (₹2,000/month)
# Docs: https://kite.trade/docs/connect/v3/
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=

# ─── Binance (Crypto 24/7) ───────────────────────────────────────
# Sign up: https://www.binance.com/en/my/settings/api-management
# Docs: https://binance-docs.github.io/apidocs/
BINANCE_API_KEY=
BINANCE_SECRET=

# ─── Alpaca (US Stocks) ─────────────────────────────────────────
# Sign up: https://alpaca.markets (Free)
# Docs: https://docs.alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# ─── Trading Config (optional overrides) ─────────────────────────
# SYMBOLS=NSE:RELIANCE,NSE:TCS,NSE:INFY,NSE:HDFCBANK,NSE:SBIN
# SYMBOLS=AAPL,TSLA,GOOGL,MSFT,NVDA
# TIMEFRAME=1h
# PAPER_CAPITAL=100000
